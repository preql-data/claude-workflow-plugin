{
  "_comment": "Fixture settings — mirrors what a real claude-workflow-plugin install lands in a consumer project. The hooks reference $CLAUDE_PROJECT_DIR/.claude/scripts which the harness ensures is a copy of the plugin's scripts/ at fixture build time. The model is pinned (claude-opus-4-7) for cassette stability — see G8 plan, 'Determinism strategy' §4. Each hook command prepends $CLAUDE_PROJECT_DIR/.claude/bin to PATH so the bd shim (workaround for bd 0.47.1 daemon-autostart stack overflow, claude-workflow-plugin-0wk.5/0wk.6) is picked up by hook subprocesses — Claude Code does NOT expand ${VAR} inside settings.json env (anthropics/claude-code#4276), so inline PATH prefix is the only reliable mechanism.",
  "additionalDirectories": [],
  "env": {
    "MAX_THINKING_TOKENS": "64000",
    "CLAUDE_LATEST_OPUS": "claude-opus-4-7"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/session-start.sh\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/intent-router.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/subagent-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/prevent-orchestrator-edits.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/post-edit.sh\"",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/bd-github-link.sh\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/verify-before-stop.sh\"",
            "timeout": 1320000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$CLAUDE_PROJECT_DIR/.claude/bin:$PATH\" bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/session-end.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "Bash",
      "Task",
      "WebFetch",
      "WebSearch"
    ]
  }
}
